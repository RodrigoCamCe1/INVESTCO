# ====================================================================
# CONFIGURATION
# ====================================================================

# Aplicación
NEXT_PUBLIC_APP_NAME=Investco ERP
NEXT_PUBLIC_APP_VERSION=1.0.0
NODE_ENV=development

# ====================================================================
# API CONFIGURATION
# ====================================================================

# URL base del backend (NestJS)
NEXT_PUBLIC_API_URL=http://localhost:3001

# JWT
NEXT_PUBLIC_JWT_TOKEN_KEY=investco_token

# ====================================================================
# AUTENTICACIÓN
# ====================================================================

# URL de login para redirecciones
NEXT_PUBLIC_LOGIN_URL=/auth/login
NEXT_PUBLIC_LOGOUT_URL=/auth/login

# ====================================================================
# ZONAS HORARIAS Y LOCALIZACIÓN
# ====================================================================

# Zona horaria para Bolivia (America/La_Paz)
NEXT_PUBLIC_TIMEZONE=America/La_Paz

# Idioma por defecto
NEXT_PUBLIC_DEFAULT_LOCALE=es-BO

# ====================================================================
# CARACTERÍSTICAS DE APP (Feature Flags)
# ====================================================================

# PWA - Progressive Web App
NEXT_PUBLIC_ENABLE_PWA=true
NEXT_PUBLIC_ENABLE_OFFLINE_QUEUE=true

# Funcionalidades específicas del ERP
NEXT_PUBLIC_ENABLE_REAL_ESTATE=true
NEXT_PUBLIC_ENABLE_PROJECT_MANAGEMENT=true
NEXT_PUBLIC_ENABLE_ANALYTICS=true
NEXT_PUBLIC_ENABLE_MOBILE_APP=true

# ====================================================================
# TERCEROS Y INTEGRACIONES
# ====================================================================

# Google Maps (si se requiere para ubicación de inmuebles)
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# Analytics
NEXT_PUBLIC_GA_ID=

# Sentry (Error tracking)
NEXT_PUBLIC_SENTRY_DSN=

# ====================================================================
# DESARROLLO
# ====================================================================

# Debug mode
DEBUG=false

# Mock API responses (para desarrollo sin backend)
NEXT_PUBLIC_USE_MOCK_API=false
